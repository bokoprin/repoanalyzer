+from __future__ import annotations
+
+import re
+from dataclasses import dataclass
+
+from .inactive_regions import is_always_false_if_expression
+
+_IF_RE = re.compile(r"^\s*#\s*(?P<directive>ifdef|ifndef|if)\s+(?P<expr>.+?)\s*(?://.*)?$")
+_ELIF_RE = re.compile(r"^\s*#\s*elif\s+(?P<expr>.+?)\s*(?://.*)?$")
+_ELSE_RE = re.compile(r"^\s*#\s*else\b")
+_ENDIF_RE = re.compile(r"^\s*#\s*endif\b")
+
+
+@dataclass(frozen=True)
+class ConditionalGuard:
+    directive: str
+    expression: str
+    line: int
+
+    def to_dict(self) -> dict[str, str | int]:
+        return {"directive": self.directive, "expression": self.expression, "line": self.line}
+
+
+@dataclass
+class _Frame:
+    opening_directive: str
+    opening_expression: str
+    opening_status: str
+    current_guard: ConditionalGuard | None
+    had_conditional_branch: bool = False
+
+
+def is_always_true_if_expression(expression: str) -> bool:
+    """Return True for the tiny, safe subset of #if expressions we can prove active."""
+    normalized = expression.strip()
+    while normalized.startswith("(") and normalized.endswith(")"):
+        inner = normalized[1:-1].strip()
+        if not inner:
+            break
+        normalized = inner
+    return normalized == "1"
+
+
+def conditional_guard_stacks_by_line(text: str) -> dict[int, list[ConditionalGuard]]:
+    """Return unresolved preprocessor guards that affect each source line.
+
+    This intentionally does not try to evaluate project macros yet.  It marks
+    only branches whose activity depends on an unresolved preprocessor
+    condition, while leaving the deterministic `#if 0` inactive case to
+    inactive_regions.py.
+    """
+    guards_by_line: dict[int, list[ConditionalGuard]] = {}
+    stack: list[_Frame] = []
+
+    for lineno, line in enumerate(text.splitlines(), start=1):
+        m_if = _IF_RE.match(line)
+        if m_if:
+            directive = m_if.group("directive")
+            expression = m_if.group("expr").strip()
+            status = _opening_status(directive, expression)
+            guard = None
+            had_conditional = False
+            if status == "conditional":
+                guard = ConditionalGuard(directive=directive, expression=expression, line=lineno)
+                had_conditional = True
+            stack.append(
+                _Frame(
+                    opening_directive=directive,
+                    opening_expression=expression,
+                    opening_status=status,
+                    current_guard=guard,
+                    had_conditional_branch=had_conditional,
+                )
+            )
+            continue
+
+        m_elif = _ELIF_RE.match(line)
+        if m_elif:
+            if stack:
+                expression = m_elif.group("expr").strip()
+                frame = stack[-1]
+                frame.current_guard = _elif_guard(expression, lineno, frame)
+                if frame.current_guard is not None:
+                    frame.had_conditional_branch = True
+            continue
+
+        if _ELSE_RE.match(line):
+            if stack:
+                frame = stack[-1]
+                frame.current_guard = _else_guard(lineno, frame)
+                if frame.current_guard is not None:
+                    frame.had_conditional_branch = True
+            continue
+
+        if _ENDIF_RE.match(line):
+            if stack:
+                stack.pop()
+            continue
+
+        active_guards = [frame.current_guard for frame in stack if frame.current_guard is not None]
+        if active_guards:
+            guards_by_line[lineno] = list(active_guards)
+
+    return guards_by_line
+
+
+def _opening_status(directive: str, expression: str) -> str:
+    if directive == "if":
+        if is_always_false_if_expression(expression):
+            return "inactive"
+        if is_always_true_if_expression(expression):
+            return "active"
+    return "conditional"
+
+
+def _elif_guard(expression: str, lineno: int, frame: _Frame) -> ConditionalGuard | None:
+    if frame.opening_status == "active" and not frame.had_conditional_branch:
+        # `#if 1` already selected the first branch; later branches are outside
+        # this MVP's inactive marking and should not be reported as conditional.
+        return None
+    if is_always_false_if_expression(expression):
+        return None
+    if is_always_true_if_expression(expression) and not frame.had_conditional_branch:
+        return None
+    return ConditionalGuard(directive="elif", expression=expression, line=lineno)
+
+
+def _else_guard(lineno: int, frame: _Frame) -> ConditionalGuard | None:
+    if frame.opening_status == "inactive" and not frame.had_conditional_branch:
+        # Else branch of `#if 0` is known active.
+        return None
+    if frame.opening_status == "active" and not frame.had_conditional_branch:
+        return None
+    expression = f"else of {frame.opening_expression}"
+    return ConditionalGuard(directive="else", expression=expression, line=lineno)
