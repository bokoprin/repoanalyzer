+def _fact_conditional_guards(fact: CodeFact, conditional_guards: dict[int, list[ConditionalGuard]]) -> list[ConditionalGuard]:
+    lines = [fact.start_line] if fact.fact_type == "symbol" else range(fact.start_line, fact.end_line + 1)
+    guards: list[ConditionalGuard] = []
+    seen: set[tuple[str, str, int]] = set()
+    for line in lines:
+        for guard in conditional_guards.get(line, []):
+            key = (guard.directive, guard.expression, guard.line)
+            if key not in seen:
+                guards.append(guard)
+                seen.add(key)
+    return guards
